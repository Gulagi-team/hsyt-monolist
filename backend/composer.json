{
    "name": "medical-profile/backend",
    "description": "Backend API for Medical Profile Management System",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "monolog/monolog": "^3.4",
        "php-di/php-di": "^7.0",
        "vlucas/phpdotenv": "^5.5",
        "firebase/php-jwt": "^6.8",
        "respect/validation": "^2.2",
        "tuupola/cors-middleware": "^1.4",
        "guzzlehttp/guzzle": "^7.10",
        "aws/aws-sdk-php": "^3.359"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public",
        "test": "phpunit"
    }
}
